# Copy this file to .env.local and fill in values for local development.
# Production values are managed via 1Password (.env.1password).

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local anon key from `supabase status`>

# JWT secret for signing group auth tokens.
# For local Supabase (supabase start), use the default secret below.
# For production, this is stored in 1Password as op://TOTF/Supabase/jwt_secret.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
